# ──────────────────────────────────────────────────────────────
# Monster Quote System – 環境變數範本
# 複製此檔案為 .env 並填入正確值
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=monster_quote_db
POSTGRES_EXTERNAL_PORT=5433          # NAS 對外暴露的 DB port

# ── API (NestJS) ───────────────────────────────────────────────
API_PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_this

# CORS：允許前端網址，多個用逗號分隔
# LAN 模式：http://192.168.1.100:3001
# SSL 模式：https://quote.example.com
CORS_ORIGIN=http://YOUR_NAS_IP:3001

# ── Frontend (Next.js) ─────────────────────────────────────────
WEB_PORT=3001
# 瀏覽器直接存取 API 的網址（非容器內部網址）
# LAN 模式：http://YOUR_NAS_IP:3000
# SSL 模式（透過 nginx）：https://quote.example.com/api
NEXT_PUBLIC_API_BASE_URL=http://YOUR_NAS_IP:3000

# ── 舊版相容（單獨使用 prisma CLI 時）─────────────────────────
DATABASE_URL=postgresql://admin:your_strong_password_here@YOUR_NAS_IP:5433/monster_quote_db?schema=public

# ── Agent C：Nginx / SSL（Let's Encrypt）──────────────────────
# 您的網域名稱（需先將 DNS 指向此伺服器）
# 無自訂網域則留空，nginx 以 LAN IP 運作
DOMAIN=quote.example.com

# Let's Encrypt 憑證通知信箱（申請 SSL 必填）
CERTBOT_EMAIL=your@email.com

# ── Agent D：PostgreSQL 自動備份 ─────────────────────────────
# 備份保留天數（預設 7 天）
BACKUP_RETENTION_DAYS=7

# ── 通知系統（Email / SMTP）──────────────────────────────────
# 支援 Gmail、Outlook、自架 SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Monster Quote System <your@gmail.com>
