// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum CurrencyCode {
  TWD
  USD
  JPY
  EUR
  CNY
}

enum TaxType {
  TAXABLE
  ZERO_RATED
  EXEMPT
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
  VOIDED
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
  CONVERT
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles              UserRole[]
  quotationsCreated  Quotation[]         @relation("QuotationCreatedBy")
  ordersCreated      Order[]             @relation("OrderCreatedBy")
  quotationApprovals QuotationApproval[]
  auditLogs          AuditLog[]
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  users UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Customer {
  id              String         @id @default(uuid())
  customerCode    String         @unique
  companyName     String
  taxId           String?
  address         String?
  phone           String?
  email           String?
  defaultCurrency CurrencyCode   @default(TWD)
  taxType         TaxType        @default(TAXABLE)
  paymentTerms    String?
  creditLimit     Decimal?       @db.Decimal(15, 2)
  status          CustomerStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())

  contacts   CustomerContact[]
  quotations Quotation[]
  orders     Order[]
}

model CustomerContact {
  id         String  @id @default(uuid())
  customerId String
  name       String
  phone      String?
  email      String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Product {
  id          String        @id @default(uuid())
  sku         String        @unique
  name        String
  brand       String?
  spec        String?
  unit        String        @default("pcs")
  costPrice   Decimal?      @db.Decimal(15, 2)
  listPrice   Decimal       @db.Decimal(15, 2)
  dealerPrice Decimal?      @db.Decimal(15, 2)
  minPrice    Decimal?      @db.Decimal(15, 2)
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  quotationItems QuotationItem[]
  orderItems     OrderItem[]
}

model Quotation {
  id          String          @id @default(uuid())
  quotationNo String          @unique
  customerId  String
  createdById String
  status      QuotationStatus @default(DRAFT)
  subtotal    Decimal         @db.Decimal(15, 2)
  taxAmount   Decimal         @db.Decimal(15, 2)
  totalAmount Decimal         @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())

  customer  Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User                @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items     QuotationItem[]
  versions  QuotationVersion[]
  approvals QuotationApproval[]
  orders    Order[]
}

model QuotationItem {
  id           String   @id @default(uuid())
  quotationId  String
  productId    String?
  productName  String
  qty          Decimal  @db.Decimal(12, 2)
  unitPrice    Decimal  @db.Decimal(15, 2)
  discountRate Decimal? @db.Decimal(5, 2)
  amount       Decimal  @db.Decimal(15, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model QuotationVersion {
  id          String   @id @default(uuid())
  quotationId String
  versionNo   Int
  snapshot    Json
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, versionNo])
}

model QuotationApproval {
  id          String         @id @default(uuid())
  quotationId String
  approverId  String
  action      ApprovalAction @default(PENDING)
  createdAt   DateTime       @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approver  User      @relation(fields: [approverId], references: [id], onDelete: Restrict)
}

model Order {
  id          String      @id @default(uuid())
  orderNo     String      @unique
  quotationId String?
  customerId  String
  createdById String
  totalAmount Decimal     @db.Decimal(15, 2)
  status      OrderStatus @default(DRAFT)
  createdAt   DateTime    @default(now())

  customer  Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotation Quotation?  @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  createdBy User        @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items     OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String?
  productName String
  qty         Decimal @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  amount      Decimal @db.Decimal(15, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  module    String
  recordId  String
  action    AuditAction
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
