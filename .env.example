# ──────────────────────────────────────────────────────────────
# Monster Quote System – 環境變數範本
# 複製此檔案為 .env 並填入正確值
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=monster_quote_db
POSTGRES_EXTERNAL_PORT=5433          # NAS 對外暴露的 DB port

# ── API (NestJS) ───────────────────────────────────────────────
API_PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_this

# CORS：允許前端網址，多個用逗號分隔
# 範例：http://192.168.1.100:3001,https://quote.example.com
CORS_ORIGIN=http://YOUR_NAS_IP:3001

# ── Frontend (Next.js) ─────────────────────────────────────────
WEB_PORT=3001
# 瀏覽器直接存取 API 的網址（非容器內部網址）
NEXT_PUBLIC_API_BASE_URL=http://YOUR_NAS_IP:3000

# ── 舊版相容（單獨使用 prisma CLI 時）─────────────────────────
DATABASE_URL=postgresql://admin:your_strong_password_here@YOUR_NAS_IP:5433/monster_quote_db?schema=public
